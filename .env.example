# Supabase (backend for projects cloud save / My Projects)
# Dashboard: https://supabase.com/dashboard → Project Settings → API
#
# VITE_ prefix is required — Vite exposes only these to the browser.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Sound Conversion (MusicEnhancer) — POST /enhance. Run: python scripts/music_enhancer_server.py
# VITE_MUSIC_ENHANCER_URL=http://localhost:8000

# Ableton Link (Approach 3) — WebSocket to local bridge. Run: npm run link-server
# Without native @ktamas77/abletonlink the server runs in STUB mode (tempo over WS only).
# Real P2P sync: npm install @ktamas77/abletonlink (may need VS Build Tools on Windows).
# VITE_ABLETON_LINK_WS=ws://127.0.0.1:8080/ws
