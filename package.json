{
	"name": "da-music-box-v2",
	"description": "Professional browser-based DAW with AI music generation",
	"packageManager": "bun",
	"private": true,
	"version": "2.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"build": "vite build",
		"preview": "vite preview",
		"music-enhancer-server": "python scripts/music_enhancer_server.py",
		"link-server": "node scripts/link-server.cjs",
		"link-server:stub": "node -e \"process.env.LINK_STUB='1';require('./scripts/link-server.cjs')\"",
		"export": "npm run build && npm run package-export",
		"package-export": "node scripts/export.js",
		"build:sound-families": "node scripts/build-sound-families.mjs",
		"validate:vocal-dsp": "bun run scripts/validate-vocal-dsp.ts"
	},
	"keywords": [
		"daw",
		"music-production",
		"audio",
		"ai",
		"sequencer",
		"synthesizer",
		"mixer"
	],
	"author": "Da Music Box Team",
	"license": "MIT",
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@magenta/music": "^1.23.0",
		"@radix-ui/react-icons": "1.3.2",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tabs": "^1.1.3",
		"@radix-ui/react-tooltip": "^1.2.7",
		"@supabase/supabase-js": "^2.99.3",
		"@uibakery/data": "0.0.13",
		"@vitejs/plugin-react": "^5.1.4",
		"canvas-confetti": "1.9.3",
		"class-variance-authority": "0.7.0",
		"clsx": "2.1.1",
		"lucide-react": "0.446.0",
		"midi-file": "^1.2.4",
		"react": "19.2.1",
		"react-day-picker": "^9.7.0",
		"react-dom": "19.2.1",
		"react-icons": "~5.5.0",
		"smplr": "^0.26.0",
		"tailwind-merge": "2.5.2",
		"vite": "^5.4.21"
	},
	"optionalDependencies": {
		"@ktamas77/abletonlink": "^1.2.3"
	},
	"devDependencies": {
		"@eslint/js": "9.11.1",
		"@types/node": "22.7.3",
		"@types/react": "19.2.1",
		"@types/react-dom": "19.2.1",
		"autoprefixer": "10.4.20",
		"classic-level": "^3.0.0",
		"eslint": "9.11.1",
		"eslint-plugin-react-hooks": "5.1.0-rc.0",
		"eslint-plugin-react-refresh": "0.4.12",
		"express": "^4.22.1",
		"express-ws": "^5.0.2",
		"globals": "15.9.0",
		"jsdom": "^28.1.0",
		"playwright": "^1.60.0",
		"postcss": "8.4.47",
		"tailwindcss": "3.4.13",
		"typescript": "5.5.3",
		"typescript-eslint": "8.7.0"
	}
}
